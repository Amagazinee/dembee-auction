# Copy to android/key.properties and fill in your upload keystore details.
# NEVER commit key.properties or the .jks file.
#
# Generate keystore (Windows — use Android Studio bundled JDK if keytool is not in PATH):
#   & "C:\Program Files\Android\Android Studio\jbr\bin\keytool.exe" -genkey -v ^
#     -keystore C:\Users\user\dembee-upload-key.jks -keyalg RSA -keysize 2048 ^
#     -validity 10000 -alias dembee
#
# storeFile can be absolute or relative to the android/ folder.
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=dembee
storeFile=C:/Users/user/dembee-upload-key.jks
