rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSeedAdminEmail() {
      return isSignedIn()
        && request.auth.token.email == 'admin@dembee.mn';
    }

    function isValidBidIncrement(amount) {
      return amount in [1, 2, 3, 4, 5];
    }

    function isValidPackageIncrement(delta) {
      return delta in [10, 20, 40, 60, 100, 200];
    }

    // --- users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['name', 'phone', 'email', 'createdAt'])
        && (
          (
            request.resource.data.role == 'user'
            && (!('bidBalance' in request.resource.data)
                || request.resource.data.bidBalance == 0)
          )
          ||
          (
            isSeedAdminEmail()
            && request.resource.data.role == 'admin'
            && (!('bidBalance' in request.resource.data)
                || request.resource.data.bidBalance == 0)
          )
        );
      allow update: if isOwner(userId) && (
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'createdAt'])
        )
        ||
        (
          isSeedAdminEmail()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])
          && request.resource.data.role == 'admin'
          && resource.data.get('role', 'user') == 'user'
        )
        ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bidBalance'])
          && request.resource.data.bidBalance == resource.data.bidBalance - 1
        )
        ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bidBalance'])
          && request.resource.data.bidBalance > resource.data.bidBalance
          && isValidPackageIncrement(
            request.resource.data.bidBalance - resource.data.bidBalance
          )
        )
      );
      allow delete: if isOwner(userId);
    }

    // --- auctions ---
    match /auctions/{auctionId} {
      allow read: if isSignedIn();

      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['title', 'price', 'endsAt', 'status'])
        && request.resource.data.price >= 0
        && request.resource.data.status in ['pending', 'active'];

      allow update: if isSignedIn() && (
        isAdmin()
        ||
        (
          resource.data.status == 'active'
          && request.resource.data.status == 'active'
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'price',
                'lastBidder',
                'lastBidUid',
                'lastBidAmount',
                'totalBids',
                'winCountdownEndsAt',
                'updatedAt'
              ])
          && request.resource.data.price == resource.data.price
              + request.resource.data.lastBidAmount
          && isValidBidIncrement(request.resource.data.lastBidAmount)
          && request.resource.data.lastBidUid == request.auth.uid
          && request.resource.data.totalBids
              == resource.data.get('totalBids', 0) + 1
          && request.resource.data.phase == resource.data.get('phase', 1)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['winnerUid', 'winnerName', 'finalPrice', 'phaseStartedAt'])
        )
      );

      allow delete: if isAdmin();
    }

    // --- auctionHistory ---
    match /auctionHistory/{historyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid;
      allow update, delete: if false;
    }

    // --- purchases (санал багц) ---
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (
        resource.data.userUid == request.auth.uid
        || isAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.paymentMethod == 'test'
        && request.resource.data.status == 'completed';
      allow update, delete: if false;
    }
  }
}
